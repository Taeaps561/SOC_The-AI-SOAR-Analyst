# Wazuh Manager API (Port 55000)
WAZUH_HOST=https://your-wazuh-manager-ip:55000
WAZUH_USER=admin
WAZUH_PASSWORD=your-password

# Wazuh Indexer API (Port 9200)
WAZUH_INDEXER_HOST=https://your-indexer-ip:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=your-password

# LLM Configuration (Local Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Application Configuration
POLL_INTERVAL=60
LOG_LEVEL=INFO
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
